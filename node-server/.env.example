# Google AI Studio API key — powers speech + vision understanding.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Server port (default: 8000)
# PORT=8000

# Optional overrides
# GEMINI_MODEL=gemini-2.5-flash
# Bengali TTS voice (Microsoft Edge TTS — free, no key).
# bn-BD-PradeepNeural (Bangladesh, male) / bn-BD-NabanitaNeural (Bangladesh, female)
# TTS_VOICE=bn-BD-PradeepNeural

# ── Real-time variant only (npm run live) — Gemini Live API ──
# LIVE_MODEL=gemini-3.1-flash-live-preview
# LIVE_PORT=8001
# LIVE_VOICE=Charon
