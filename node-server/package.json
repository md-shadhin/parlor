{
  "name": "parlor-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node.js real-time voice+vision server for Parlor — Bengali, powered by the Gemini API",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsx server.ts",
    "dev": "tsx watch server.ts",
    "live": "tsx live.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/text.test.ts"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@ricky0123/vad-web": "^0.0.29",
    "dotenv": "^16.4.5",
    "msedge-tts": "^2.0.6",
    "onnxruntime-web": "^1.22.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
